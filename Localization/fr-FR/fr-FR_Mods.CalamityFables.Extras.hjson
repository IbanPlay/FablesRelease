ArmorSetBonus: {
	MarniteArchitect: {
		Title: Cric de Marnite - Vous pouvez déployer un cric sous vos pieds pour atteindre plus haut
		Tooltip1: Le cric est deployé lorsque vous essayez d'invoquer votre monture [c/D4C870:sans avoir une monture déjà équipée]
		Tooltip2: Utilisez la touche Haut et Bas pour changer la hauteur du cric
	}

	DesertProwler: {
		Title: Tourbillion de sable - Courrir sur le sol entraîne une tornade de sable avec vous
		Tooltip1: Lorsque le tourbillion est complêtement chargé, vous pouvez performer un saut propulsé en sautant avec la touche Haut appuyée
		Tooltip2: Pendant la duration du saut propulsé, vous gagnez {0}% de dégâts a distance supplémentaires
	}

	Sailfish: {
		Title: Destrier Royal - Vous pouvez invoquer un vélocicampe de joute royale
		Tooltip1: Le destrier est invoqué lorsque vous essayez d'invoquer votre monture [c/be9137:sans avoir une monture déjà équipée]
		Tooltip2: Le destrier approte {0}% de chances de coup critique de mêlée
		Tooltip3: Les lances gagnent {0} de dégâts supplémentaires sur le vélocicampe
	}

	Wulfrum: {
		Title: Bastion de Wulfrum - Appuyez deux fois sur Bas pour equipper une exosquelette Wulfrum (tant que vous n'êtes pas sur une monture)
		Tooltip1: Pendant que l'exosquelette est actif vos défenses sont fortifiées, mais vous ne pouvez utiliser que le cannon à fusion intégré
		Tooltip2: Equipper l'exosquelette requiert une pièce de [c/b0e97a:ferraile Wulfrum], et l'exosquelette perdra de la durabilité plus rapidement quand vous recevez des coups
		ExpandCannonInfo: Maintenez SHIFT pour voir les statistiques du cannon à fusion
	}

	// IceHat: Mana Condensation - Greatly increased mana regeneration while encased
}

