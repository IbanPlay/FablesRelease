	Name27: Sebae
	Name28: Aurea
	Name29: Oro
	Name30: Acantha
	Name31: Conoa
}

DeathMessages: {
	DesertScourgeChungry: {
		1: "{0}变成了橙汁的果肉。"
		2: "{0}现在是鱼饵了。"
		3: "{0}变成了美味小吃。"
		4: "{0}成为了主菜的佐料。"
	}

	DesertScourgeSkullCrush: {
		// 1: "{0} was mauriced."
		2: 重力对{0}的王国来说是场灾难。
		3: "[i:{1}][i:{1}][i:{1}] {0} [i:{1}][i:{1}][i:{1}]"
		4: "{0}被骨头击中了。"
		5: "{0}成为了牛顿引力定律的牺牲品。"
	}

	DesertScourgeAntlionSpit: "{0}已被熔化。"

	DesertScourgeElectroblast: {
		1: "{0}需要考虑下死亡。"
		2: "{0}有相当震惊的经历。"
		3: "{0}这个月的电费将会很高。"
	}

	CrabulonSpores: {
		1: "{0}变成了真菌意志的一部分。"
		2: 蘑菇洞穴将{0}视为新的契合宿主。
		3: "{0}爆发成孢子了。"
		4: "{0}已被同化。"
		5: "{0}将成为不错的天花板装饰。"
	}

	CrabulonDropSlam: {
		1: "{0}被压扁成了蘑菇味煎饼。"
		2: "{0}变成了蘑菇肥料。"
		3: 菌生蟹加速了{0}的分解。
		4: "{0}没有空间躲避了。"
	}

	CrabulonClaw: {
		1: "{0}感觉很蓝受。"
		2: "{0}某天可能会被搅拌进治疗药水。"
		3: "{0}的身体留在了蘑菇洞穴。"
		4: "{0}已被收割。"
	}

	SandTwisterFall: {
		1: "{0} 与尘魔达成了协议。"
		2: "{0} 搞砸了。"
		3: "{0} 变得一团糟。"
		4: 睡魔让 {0} 安息了。
	}

	OpulentSelfInjection: {
		1: "{0} 对针头产生了恐惧。"
		2: "{0} 成为了自己玩忽职守的受害者。"
	}

	OpulentInjection: {
		// 1: "{0} has a newfound fear of needles."
		// 2: "{0} was a victim of {1}'s malpractice."
	}

	OpulentOverdose: {
		1: "{0} 忘记了读副作用说明。"
		2: "{0} 自食其果了。"
		3: "{0}的器官迸裂了。"
	}
}

