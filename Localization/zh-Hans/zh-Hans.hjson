					'''
			}

			WulfrumAcrobaticsPack: {
				DisplayName: 钨钢杂技背包
				Tooltip:
					'''
					盒子里的这堆齿轮和电线重组了钩爪装置，将它们转化为钨钢弹弓
					按住上键会收回钩爪
					在侦测到致命跌落时会自动尝试抓住附近的墙壁
					若此时长按下键，此安全功能将不会激活
					增加 {0}% 移动速度
					'''
			}

			WulfrumBlunderbuss: {
				DisplayName: 钨钢火铳
				Tooltip:
					'''
					消耗钨钢金属废料或银币开火
					无视敌怪3点防御
					[c/83B87E:“钨钢的好处是虽然随便就碎了，但它可以很快就二次利用”]
					[c/83B87E:“事实上，机器人停工后即刻变成弹药是很常见的”]
					'''
			}

			WulfrumController: {
				DisplayName: 钨钢控制器
				Tooltip:
					'''
					召唤一架钨钢无人机为你而战
					手持遥控器时长按 <right> 以使你的无人机进入增压模式
					增压的无人机会停止攻击并为你聚集钨钢能量
					能量束会提供额外的生命再生和防御
					保持你的光标离其他玩家足够近的话可以治疗他们
					'''
			}

			WulfrumDiggingTurtle: {
				DisplayName: 钨钢掘地机械龟
				Tooltip:
					'''
					投掷一个不结实的采矿装置来挖掘一条小隧道
					在紧急情况下，<right> 可立即引爆所有挖掘机械龟
					'''
			}

			WulfrumDrill: {
				DisplayName: 钨钢钻头
				Tooltip: ""
			}

			WulfrumFusionCannon: {
				DisplayName: 试作型钨钢聚变炮
				Tooltip:
					'''
					发射快速的中射程弹幕
					[c/878787:“自己变成召唤物后，谁还需要一根鞭子呢？”]
					'''
			}

			WulfrumHat: {
				DisplayName: 钨钢工程帽
				Tooltip:
					'''
					增加10%鞭子范围
					自带假发
					'''
			}

			WulfrumJacket: {
				DisplayName: 钨钢夹克
				Tooltip: 增加5%伤害减免
			}

			WulfrumMetalScrap: {
				DisplayName: 钨钢金属废料
				Tooltip: ""
			}

			WulfrumOveralls: {
				DisplayName: 钨钢工装裤
				Tooltip: 增加5%移动速度
			}

			WulfrumProsthesis: {
				DisplayName: 钨钢义肢
				Tooltip:
					'''
					释放钨钢能量
					<right> 对面前的生物进行法力汲取
					[c/83B87E:科技和魔法永远被定格在效仿与复仇的军备竞赛中]
					[c/83B87E:有时它们是协作的，如某些义肢]
					'''
			}

			WulfrumScaffoldKit: {
				DisplayName: 钨钢云梯工具包
				Tooltip:
					'''
					放置临时金属脚手架。每建造40块便会消耗一块钨钢金属废料
					脚手架需要从实心物块开始放置
					[c/83B87E:“为你需要速建而不需要持续效果的东西而存在。”]
					'''
			}

			WulfrumScrewdriver: {
				DisplayName: 钨钢螺丝刀
				Tooltip:
					'''
					可以快速有力地消灭敌人，只要它们足够虚弱
					攻击敌人有概率给予你一把钨钢螺丝，你可以 <right> 将其扔回去
					用螺丝刀击中被甩出的螺丝会增加它的伤害和速度，使它高速向前猛冲
					[c/83B87E:“是谁把平头螺丝刀做的这么大？？我他妈到底能用它来干啥？这东西甚至可以直接把人的眼睛挖出来！”]
					[c/83B87E:“……啊。”]
					'''
			}

			WulfrumTreasurePinger: {
				DisplayName: 钨钢探测仪
				Tooltip:
					'''
					帮助你找到比钨钢更有价值的金属
					这个破东西看起来质量太差了。[c/fc4903:它迟早会坏掉]
					'''
			}

