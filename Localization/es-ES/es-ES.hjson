					'''
			}

			WulfrumAcrobaticsPack: {
				DisplayName: Paquete Acrobático de Wulfrum
				Tooltip:
					'''
					Convierte tu gancho en un gancho de wulfrum con físicas de columpio
					Mantén ARRIBA para retraer el gancho
					Intenta engancharte automáticamente si estás a punto de sufrir daño por caída, presiona ABAJO para evitar esto
