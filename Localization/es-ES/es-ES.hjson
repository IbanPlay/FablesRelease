				}

				Nautilus: {
					SpawnInfo: Conoce al soldado solitario en la cámara oculta debajo de las dunas... ¡Un antiguo [i:{0}] cementerio marca el lugar!
					Despawn: ¡Nautilo gana el duelo!
				}
			}
		}

