		Conditions.InNautilusChamber: Dentro de la Cámara Sellada

		Compat: {
			BossChecklist: {
				DesertScourge: {
					SpawnInfo: Atrae al Asaltadunas con [i:{0}][i:{1}][i:{2}] deliciosas larvas de electroleón.
					Despawn: El Asaltadunas se hace uno con la arena...
				}

				Crabulon: {
					SpawnInfo: Puede aparecer naturalmente en las cuevas champiñón antes de ser derrotado. Atráelo con un [i:{0}] corquete en césped champiñón.
