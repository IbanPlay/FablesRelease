					'''
			}

			WulfrumBlunderbuss: {
				DisplayName: Trabuco de Wulfrum
				Tooltip:
					'''
					Consume chatarra de wulfrum o monedas de plata para disparar
					Ignora 3 puntos de la defensa del enemigo
					[c/83B87E:"Lo bueno del wulfrum es que, aunque se rompe rápido, se puede reusar aún más rápido"]
					[c/83B87E:"De hecho, es muy común que un robot se convierta en munición justo despúes de dejar de funcionar"]
					'''
			}

			WulfrumController: {
				DisplayName: Control de Wulfrum
				Tooltip:
					'''
					Invoca a un droide de wulfrum para que luche por ti
					Mantén el <right> mientras sostienes el control para poner a tus droided en modo sobrecarga 
					Droides sobrecargados dejarán de atacar y concentrarán energía de wulfrum en ti
