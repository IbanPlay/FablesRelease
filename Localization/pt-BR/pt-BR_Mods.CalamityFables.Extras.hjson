DeathMessages: {
	DesertScourgeChungry: {
		1: "{0} virou suco de laranja."
		2: "{0} é a isca agora."
		3: "{0} virou um delicioso lanche."
		4: "{0} foi apenas um apetizador."
	}

	DesertScourgeSkullCrush: {
		1: "{0}, nem fudendo você morreu pra isso."
		2: Gravidade foi uma calamidade para o reino de {0}.
		3: "[i:{1}][i:{1}][i:{1}] {0} [i:{1}][i:{1}][i:{1}]"
		4: "{0} foi ossado."
		5: "{0} foi vitima das leis de Newton."
	}

	DesertScourgeAntlionSpit: "{0} derreteu."

	DesertScourgeElectroblast: {
		1: "{0} teve uma morte para refletir."
		2: "{0} teve uma experiência bem chocante."
		3: "{0} pagou a conta de luz cedo."
	}

	CrabulonSpores: {
		1: “{0} tornou-se parte da colméia micelial”.
		2: “As cavernas de cogumelos consideraram {0} como um novo hospedeiro adequado.”
		3: “{0} irrompeu em esporos.”
		4: “{0} foi assimilado.”
		5: “{0} será um belo ornamento para o teto.”
	}

	CrabulonDropSlam: {
		1: "{0} foi espremido em uma panqueca de cogumelos."
		2: "{0} virou fertilizador de cogumelo."
		3: Crustumelo acelerou a decomposição inevitável de {0}.
		4: "{0} não teve o cogu-mérito de desviar."
	}

	CrabulonClaw: {
		1: "{0} se sente azul."
		2: "{0} talvez se tornará uma poção de cura um dia."
		3: "{0} desistiu seu corpo para as cavernas de cogumelos."
		4: "{0} foi coletado."
	}

	SandTwisterFall: {
		1: "{0} fez um acordo com o re-demoni-nho."
		2: "{0} perdeu o rumo."
		3: "{0} virou pó."
		4: "{0}achou que dava pra negociar com o vento.."
	}

	OpulentSelfInjection: {
		1: "{0} agora tem medo de agulhas."
		2: "{0} foi vítima de seu próprio descuido."
	}

	OpulentInjection: {
		1: "{0} agora tem medo de agulhas."
		2: "{0} foi vítima do descuido de {1}."
	}

	OpulentOverdose: {
		1: "{0} não leu a bula."
		2: "{0} teve um gosto do próprio remédio."
		3: Os órgãos de {0} explodiram.
	}
}

