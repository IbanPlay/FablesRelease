				DisplayName: Máscara do Herói Infernal
				Tooltip: "'Motoserra Homem.'"
			}

			OldHunterHat: {
				DisplayName: Chapéu de Caçador Antigo
				Tooltip: "'Traje com a aparência de caçadores de uma terra distante'"
			}

			OldHunterPants: {
				DisplayName: Calça de Caçador Antigo
				Tooltip: "'Traje com a aparência de caçadores de uma terra distante'"
			}

			OldHunterShirt: {
				DisplayName: Camisa de de Caçador Antigo
				Tooltip: "'Traje com a aparência de caçadores de uma terra distante'"
			}

			AbandonedWulfrumHelmet: {
				DisplayName: Capacete Wulfrum Abandonado
				Tooltip:
					'''
					Um capacete desgastado e enferrujado que lembra modelos antigos de armadura wulfrum
					Transforma o portador em um robô wulfrum
					Também pode ser usado no compartimento do capacete como um capacete normal
					[Essa armadura bastante frágil era comumente usada por catadores e saqueadores].
					[c/83B87E:Sua versatilidade e natureza comum levaram-na a ser usada como moeda de troca em negociações].
					'''
			}

			EnergyCore: {
				DisplayName: Núcleo Energético
				Tooltip:
					'''
					Ele pulsa com energia
					Só pode ser obtido destruindo uma máquina Wulfrum enquanto um Nexus a estiver fortalecendo
					'''
			}

			RoverDrive: {
				DisplayName: Núcleo do Rover
				Tooltip:
					'''
					Ativa uma matriz protetora que pode absorver 50 de dano e concede 10 de defesa
					No entanto, os sistemas são inconstantes e o escudo precisará de 10 segundos para ser totalmente carregado
					Ser atingido durante o período de recarga do escudo fará com que ele volte a zero
					Também pode ser reciclado em um extrator
					'''
			}

			WulfrumAcrobaticsPack: {
				DisplayName: Kit de Acrobacias Wulfrum
				Tooltip:
					'''
					Transforma os ganchos em um estilingue wulfrum com física avançada
					               Mantenha pressionada a tecla CIMA para retrair o gancho
					               Automaticamente agarra paredes próximas quando o jogador estiver prestes a sofrer dano de queda, a menos que a tecla BAIXO esteja pressionada
					{0}% de aumento na velocidade de movimento
					'''
			}

			WulfrumBlunderbuss: {
				DisplayName: Canhão Wulfrum
				Tooltip:
					'''
					Consome Sucata de Wulfrum ou moedas de prata para disparar
					Ignora 3 pontos de defesa do inimigo
					[c/83B87E: “O bom do Wulfrum é que, embora se quebre rapidamente, ele pode ser reutilizado ainda mais rápido”].
					[c/83B87E: “De fato, é bastante comum que um robô seja transformado em munição logo após parar de funcionar”]
					'''
			}

			WulfrumController: {
				DisplayName: Controle Wulfrum
				Tooltip:
					'''
					Convoca um dróide wulfrum para lutar por você
					<right> enquanto segura o controle remoto para colocar todos os seus drones no modo sobrecarregado
					Os dróides sobrecarregados deixarão de atacar e concentrarão a energia wulfrum em você
					O feixe fornece regeneração e defesa adicionais
					Também pode ser usado para curar outros jogadores, bastando manter o cursor do mouse próximo a eles
					'''
			}

			WulfrumDiggingTurtle: {
				DisplayName: Escava-ruga Wulfrum
				Tooltip:
					'''
					Lança uma engenhoca de mineração frágil para cavar um pequeno túnel
					Em caso de emergência, <right> para detonar instantaneamente todas as suas Escava-rugas
					'''
			}

			WulfrumDrill: {
				DisplayName: Broca Wulfrum
				Tooltip: ""
			}

			WulfrumFusionCannon: {
				DisplayName: Matriz experimental de fusão Wulfrum
				Tooltip:
					'''
					Dispara rajadas rápidas de pelotas de médio alcance
					[c/878787: “Quem precisa de chicotes quando você pode simplesmente se tornar a própria invocação?”].
					'''
			}

			WulfrumHat: {
				DisplayName: Chapéu e Óculos Wulfrum
				Tooltip:
					'''
					Aumento de 10% no alcance do chicote
					Vem equipado com extensões de cabelo
					'''
			}

			WulfrumJacket: {
				DisplayName: Jaqueta Wulfrum
				Tooltip: 5% de redução de dano aumentada
			}

			WulfrumMetalScrap: {
				DisplayName: Sucata de Wulfrum
				Tooltip: ""
			}

			WulfrumOveralls: {
				DisplayName: Macacão Wulfrum
				Tooltip: 5% de aumento da velocidade de movimento
			}

			WulfrumProsthesis: {
				DisplayName: Prótese Wulfrum
				Tooltip:
					'''
					Lança um raio de wulfrum
					<right> para drenar a mana das criaturas à sua frente
					[c/83B87E:A tecnologia e a magia sempre estiveram presas em uma corrida armamentista de imitação e retaliação].
					[c/83B87E:Às vezes, elas trabalham em conjunto, como visto nesses membros protéticos].
					'''
			}

			WulfrumScaffoldKit: {
				DisplayName: Kit de Andaimes Wulfrum
				Tooltip:
					'''
					Coloca andaimes metálicos temporários. Usa uma sucata de wulfrum para 40 blocos construídos
					O andaime precisa estar adjacente a um ladrilho sólido para ser colocado
					[c/83B87E:'Para quando você precisa construir algo rápido e não precisa que dure'.]
					'''
			}

			WulfrumScrewdriver: {
				DisplayName: Chave de Fenda Wulfrum
				Tooltip:
					'''
					Pode ser usado para dar uma surra rápida e real em qualquer inimigo, desde que ele seja fraco o suficiente
					Ao atingir um inimigo, você tem a chance de receber um Parafuso wulfrum, <right> para arremesá-lo no ar.
					Atingir um parafuso arremessado com a chave de fenda aumentará seu dano e sua velocidade, fazendo com que ele seja arremessado em alta velocidade.
					[c/83B87E: “Quem faz cabeças chatas desse tamanho? Para que diabos eu vou usá-la, essa coisa pode arrancar um olho!"]
					[c/83B87E:“...Ah.”]
					'''
			}

			WulfrumTreasurePinger: {
				DisplayName: Detector de Metais Wulfrum
